APP_NAME="Il Mirto Apartment"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://ilmirtoapartment.it
APP_TIMEZONE=Europe/Rome

APP_LOCALE=it
APP_FALLBACK_LOCALE=it
APP_FAKER_LOCALE=it_IT

# Multilingua (mcamara/laravel-localization) — lingue attive in config/laravellocalization.php

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# cPanel: preferisci MySQL
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mirto_site
DB_USERNAME=mirto_user
DB_PASSWORD=

# Sviluppo locale: puoi usare sqlite
# DB_CONNECTION=sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.ilmirtoapartment.it

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="info@ilmirtoapartment.it"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo: crea SMTP key nel pannello Brevo e incolla in MAIL_PASSWORD

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
